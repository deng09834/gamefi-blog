---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="GameFi 攻略站 - 首页">
  <!-- Hero Section -->
  <section class="text-center py-20 bg-blue-50 rounded-3xl mb-12">
    <h1 class="text-5xl font-extrabold mb-6 text-slate-900 leading-tight">
      深耕 <span class="text-blue-600">GameFi</span> 赛道<br/>获取最专业的实战指南
    </h1>
    <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto">
      我们为您筛选优质链游，提供深度攻略、风险预警与收益模型分析，助您在 Web3 游戏世界稳步前行。
    </p>
    <div class="flex justify-center gap-4">
      <a href="/blog" class="bg-blue-600 text-white px-10 py-4 rounded-xl font-bold hover:bg-blue-700 shadow-lg shadow-blue-200 transition-all">
        立即开始阅读
      </a>
      <a href="/games" class="bg-white text-slate-700 border border-slate-200 px-10 py-4 rounded-xl font-bold hover:bg-slate-50 transition-all">
        发现新游戏
      </a>
    </div>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
    <!-- Left: Content Directory (Main focus) -->
    <div class="lg:col-span-2 space-y-12">
      <section>
        <div class="flex items-center justify-between mb-8 border-b border-slate-100 pb-4">
          <h2 class="text-3xl font-bold text-slate-900">📚 文章目录</h2>
          <span class="text-slate-400 text-sm">共 6 篇深度内容</span>
        </div>

        <div class="space-y-8">
          <!-- Category: Newbie Guide -->
          <div>
            <h3 class="text-sm font-bold text-blue-600 uppercase tracking-wider mb-4">🐣 新手起步</h3>
            <div class="grid gap-4">
              <a href="/blog/first-gamefi-earning" class="group flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:border-blue-400 hover:shadow-md transition-all">
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-blue-600">如何赚取第一笔 GameFi 收入</h4>
                  <p class="text-sm text-slate-500 mt-1">零基础完整指南，从钱包设置到获得首笔收益。</p>
                </div>
                <span class="text-slate-300 group-hover:text-blue-500">→</span>
              </a>
              <a href="/blog/getting-started" class="group flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:border-blue-400 hover:shadow-md transition-all">
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-blue-600">GameFi 新手入门指南</h4>
                  <p class="text-sm text-slate-500 mt-1">系统性了解 GameFi 的核心逻辑与参与方式。</p>
                </div>
                <span class="text-slate-300 group-hover:text-blue-500">→</span>
              </a>
            </div>
          </div>

          <!-- Category: Game Reviews -->
          <div>
            <h3 class="text-sm font-bold text-green-600 uppercase tracking-wider mb-4">🎮 游戏攻略</h3>
            <div class="grid gap-4">
              <a href="/games/axie-infinity" class="group flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:border-blue-400 hover:shadow-md transition-all">
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-blue-600">Axie Infinity 完全攻略</h4>
                  <p class="text-sm text-slate-500 mt-1">经典对战链游深度解析与赚钱技巧。</p>
                </div>
                <span class="text-slate-300 group-hover:text-blue-500">→</span>
              </a>
              <a href="/games/stepn" class="group flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:border-blue-400 hover:shadow-md transition-all">
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-blue-600">StepN 实战指南</h4>
                  <p class="text-sm text-slate-500 mt-1">Move to Earn 领头羊的入场选择与回本周期分析。</p>
                </div>
                <span class="text-slate-300 group-hover:text-blue-500">→</span>
              </a>
            </div>
          </div>

          <!-- Category: Advanced Strategy -->
          <div>
            <h3 class="text-sm font-bold text-purple-600 uppercase tracking-wider mb-4">💡 进阶策略</h3>
            <div class="grid gap-4">
              <a href="/blog/earning-strategy" class="group flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:border-blue-400 hover:shadow-md transition-all">
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-blue-600">GameFi 收益最大化策略</h4>
                  <p class="text-sm text-slate-500 mt-1">从多个维度优化投资组合与时间分配收益。</p>
                </div>
                <span class="text-slate-300 group-hover:text-blue-500">→</span>
              </a>
              <a href="/blog/2026-gamefi-trends" class="group flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:border-blue-400 hover:shadow-md transition-all">
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-blue-600">2026 年 GameFi 趋势预测</h4>
                  <p class="text-sm text-slate-500 mt-1">深度分析行业未来动向，发掘下一个潜力赛道。</p>
                </div>
                <span class="text-slate-300 group-hover:text-blue-500">→</span>
              </a>
            </div>
          </div>

          <!-- Category: Risk Management -->
          <div>
            <h3 class="text-sm font-bold text-red-600 uppercase tracking-wider mb-4">🛡️ 安全与风险</h3>
            <div class="grid gap-4">
              <a href="/blog/anti-scam" class="group flex items-center justify-between p-4 bg-white border border-slate-200 rounded-xl hover:border-blue-400 hover:shadow-md transition-all">
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-blue-600">GameFi 防骗必备指南</h4>
                  <p class="text-sm text-slate-500 mt-1">识破常见骗局，保护您的资产免受损失。</p>
                </div>
                <span class="text-slate-300 group-hover:text-blue-500">→</span>
              </a>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Right: Sidebar -->
    <aside class="space-y-8">
      <div class="bg-slate-900 text-white p-8 rounded-3xl">
        <h3 class="text-xl font-bold mb-4">🚀 快速加入</h3>
        <p class="text-slate-400 text-sm mb-6 leading-relaxed">
          加入我们的社群，获取每日最新的链游空投信息和深度项目点评。
        </p>
        <div class="space-y-3">
          <a href="#" class="block w-full text-center py-3 bg-blue-600 rounded-xl font-bold hover:bg-blue-700 transition">Telegram 频道</a>
          <a href="#" class="block w-full text-center py-3 bg-white text-slate-900 rounded-xl font-bold hover:bg-slate-100 transition">官方 Twitter</a>
        </div>
      </div>

      <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100">
        <h3 class="text-xl font-bold text-slate-900 mb-4">🛠️ 实用工具</h3>
        <ul class="space-y-4">
          <li>
            <a href="/tools" class="flex items-center gap-3 text-slate-600 hover:text-blue-600 transition">
              <span class="w-8 h-8 flex items-center justify-center bg-white rounded-lg text-lg">🧮</span>
              <span class="font-medium">收益计算器</span>
            </a>
          </li>
          <li>
            <a href="#" class="flex items-center gap-3 text-slate-600 hover:text-blue-600 transition">
              <span class="w-8 h-8 flex items-center justify-center bg-white rounded-lg text-lg">⛽</span>
              <span class="font-medium">Gas 费实时监测</span>
            </a>
          </li>
          <li>
            <a href="#" class="flex items-center gap-3 text-slate-600 hover:text-blue-600 transition">
              <span class="w-8 h-8 flex items-center justify-center bg-white rounded-lg text-lg">📅</span>
              <span class="font-medium">链游上线日历</span>
            </a>
          </li>
        </ul>
      </div>
    </aside>
  </div>
</BaseLayout>
