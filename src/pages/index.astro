---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="GameFi 攻略站 - 发现、学习并掌握 Web3 游戏">
  <!-- 顶部 Banner - 现代简约明亮风格 -->
  <section class="relative overflow-hidden bg-white py-20 px-6 sm:py-32 rounded-[3rem] border border-slate-100 mb-16 shadow-sm">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(45rem_50rem_at_top,theme(colors.blue.50),white)] opacity-40"></div>
    <div class="mx-auto max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold tracking-wider uppercase mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-600"></span>
        </span>
        2026 链游实战指南已更新
      </div>
      <h1 class="text-5xl md:text-7xl font-black tracking-tight text-slate-900 mb-8 leading-[1.1]">
        让每一位玩家都能在 <span class="text-blue-600">GameFi</span> 赛道稳健获利
      </h1>
      <p class="text-lg md:text-xl text-slate-500 mb-12 max-w-2xl mx-auto leading-relaxed">
        我们为您深度拆解每一个具有潜力的链游项目，从零开始建立您的 Web3 投资策略与风险防护体系。
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#directory" class="px-10 py-5 bg-blue-600 text-white rounded-2xl font-bold hover:bg-blue-700 shadow-2xl shadow-blue-200 transition-all transform hover:-translate-y-1">
          立即开始学习
        </a>
        <a href="/tools" class="px-10 py-5 bg-slate-50 text-slate-700 border border-slate-200 rounded-2xl font-bold hover:bg-white transition-all transform hover:-translate-y-1">
          使用收益计算器
        </a>
      </div>
    </div>
  </section>

  <!-- 核心逻辑：内容导航网格 -->
  <div id="directory" class="grid grid-cols-1 lg:grid-cols-12 gap-12">
    
    <!-- 左侧：逻辑清晰的内容目录 (占 8 列) -->
    <main class="lg:col-span-8">
      <div class="flex items-center justify-between mb-12 border-b border-slate-100 pb-6">
        <div>
          <h2 class="text-3xl font-black text-slate-900 mb-2">📚 知识体系</h2>
          <p class="text-slate-400 text-sm">系统化的 GameFi 学习路径</p>
        </div>
        <div class="hidden sm:flex items-center gap-2">
          <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 hover:text-blue-600 cursor-pointer transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          </div>
        </div>
      </div>

      <div class="space-y-16">
        <!-- 模块 1: 新手必修 -->
        <section>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg bg-blue-600 text-white flex items-center justify-center text-sm font-bold shadow-lg shadow-blue-100">01</div>
            <h3 class="text-xl font-black text-slate-800 tracking-tight">新手从零起步</h3>
          </div>
          <div class="grid gap-4">
            <a href="/blog/first-gamefi-earning" class="group p-6 bg-white border border-slate-100 rounded-3xl hover:border-blue-200 hover:shadow-xl hover:shadow-slate-100 transition-all">
              <div class="flex justify-between items-start">
                <div>
                  <h4 class="text-lg font-bold text-slate-800 group-hover:text-blue-600 mb-2 transition">如何赚取第一笔 GameFi 收入</h4>
                  <p class="text-sm text-slate-500 leading-relaxed">零基础完整指南，从钱包设置到获得首笔收益，手把手教学。</p>
                </div>
                <span class="p-2 bg-slate-50 rounded-lg text-slate-300 group-hover:bg-blue-50 group-hover:text-blue-500 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </span>
              </div>
            </a>
            <a href="/blog/getting-started" class="group p-6 bg-white border border-slate-100 rounded-3xl hover:border-blue-200 hover:shadow-xl hover:shadow-slate-100 transition-all">
              <div class="flex justify-between items-start">
                <div>
                  <h4 class="text-lg font-bold text-slate-800 group-hover:text-blue-600 mb-2 transition">GameFi 核心逻辑入门</h4>
                  <p class="text-sm text-slate-500 leading-relaxed">深入浅出地讲解链游的经济模型、代币机制与参与机会。</p>
                </div>
                <span class="p-2 bg-slate-50 rounded-lg text-slate-300 group-hover:bg-blue-50 group-hover:text-blue-500 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </span>
              </div>
            </a>
          </div>
        </section>

        <!-- 模块 2: 项目实战 -->
        <section>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg bg-green-600 text-white flex items-center justify-center text-sm font-bold shadow-lg shadow-green-100">02</div>
            <h3 class="text-xl font-black text-slate-800 tracking-tight">热门项目实战</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/games/axie-infinity" class="group p-6 bg-white border border-slate-100 rounded-3xl hover:border-green-200 hover:shadow-xl hover:shadow-slate-100 transition-all">
              <div class="mb-4 w-12 h-12 bg-blue-50 rounded-2xl flex items-center justify-center text-2xl group-hover:scale-110 transition">👾</div>
              <h4 class="font-bold text-slate-800 group-hover:text-green-600 mb-1 transition">Axie Infinity</h4>
              <p class="text-xs text-slate-500">经典养成对战深度解析</p>
            </a>
            <a href="/games/stepn" class="group p-6 bg-white border border-slate-100 rounded-3xl hover:border-green-200 hover:shadow-xl hover:shadow-slate-100 transition-all">
              <div class="mb-4 w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center text-2xl group-hover:scale-110 transition">👟</div>
              <h4 class="font-bold text-slate-800 group-hover:text-green-600 mb-1 transition">StepN 实战</h4>
              <p class="text-xs text-slate-500">Move to Earn 回本周期分析</p>
            </a>
          </div>
        </section>

        <!-- 模块 3: 进阶与安全 -->
        <section>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg bg-purple-600 text-white flex items-center justify-center text-sm font-bold shadow-lg shadow-purple-100">03</div>
            <h3 class="text-xl font-black text-slate-800 tracking-tight">进阶策略与安全</h3>
          </div>
          <div class="grid gap-4">
             <!-- 新增 SEO 文章 -->
             <a href="/blog/seo-guide" class="group p-6 bg-blue-50 border border-transparent rounded-3xl hover:border-blue-200 hover:bg-white transition-all">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-xl shadow-sm">🚀</div>
                <div>
                  <h4 class="font-bold text-slate-900 group-hover:text-blue-600">2026 GameFi 网站 SEO 指南</h4>
                  <p class="text-sm text-slate-500">最新实战教程，教你如何获取免费流量。</p>
                </div>
                <div class="ml-auto px-3 py-1 bg-blue-600 text-white text-[10px] font-bold rounded-full uppercase">New</div>
              </div>
            </a>
            <a href="/blog/earning-strategy" class="group p-6 bg-white border border-slate-100 rounded-3xl hover:border-purple-200 hover:shadow-xl hover:shadow-slate-100 transition-all">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-xl group-hover:bg-purple-50 transition">💰</div>
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-purple-600">收益最大化投资模型</h4>
                  <p class="text-sm text-slate-500">从资金管理到风险规避的多维优化。</p>
                </div>
              </div>
            </a>
            <a href="/blog/anti-scam" class="group p-6 bg-white border border-slate-100 rounded-3xl hover:border-purple-200 hover:shadow-xl hover:shadow-slate-100 transition-all">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-xl group-hover:bg-red-50 transition">🛡️</div>
                <div>
                  <h4 class="font-bold text-slate-800 group-hover:text-red-600">GameFi 防骗必备指南</h4>
                  <p class="text-sm text-slate-500">保护您的加密钱包与资产安全。</p>
                </div>
              </div>
            </a>
          </div>
        </section>
      </div>
    </main>

    <!-- 右侧：简洁侧边栏 (占 4 列) -->
    <aside class="lg:col-span-4 space-y-8">
      <!-- 动态数据卡片 -->
      <div class="p-8 bg-slate-900 rounded-[2.5rem] text-white">
        <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-green-500"></span>
          市场观察员
        </h3>
        <div class="space-y-6">
          <div class="flex justify-between items-center border-b border-slate-800 pb-4">
            <span class="text-slate-400 text-sm">今日潜力项目</span>
            <span class="font-mono text-green-400">Illuvium</span>
          </div>
          <div class="flex justify-between items-center border-b border-slate-800 pb-4">
            <span class="text-slate-400 text-sm">平均回本周期</span>
            <span class="font-mono">45-60 Days</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-slate-400 text-sm">热门公链</span>
            <div class="flex gap-2">
              <span class="text-[10px] bg-slate-800 px-2 py-1 rounded-md">SOL</span>
              <span class="text-[10px] bg-slate-800 px-2 py-1 rounded-md">RON</span>
            </div>
          </div>
        </div>
        <button class="w-full mt-8 py-4 bg-blue-600 rounded-2xl font-bold hover:bg-blue-700 transition shadow-xl shadow-blue-900">
          获取深度研究报告
        </button>
      </div>

      <!-- 工具入口 -->
      <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100">
        <h3 class="text-xl font-black text-slate-900 mb-6">实用工具箱</h3>
        <div class="space-y-3">
          <a href="/tools" class="flex items-center justify-between p-4 bg-white rounded-2xl border border-slate-100 hover:border-blue-200 transition group">
            <span class="font-bold text-slate-700 group-hover:text-blue-600">收益计算器</span>
            <span class="text-lg">🧮</span>
          </a>
          <a href="#" class="flex items-center justify-between p-4 bg-white rounded-2xl border border-slate-100 hover:border-blue-200 transition group">
            <span class="font-bold text-slate-700 group-hover:text-blue-600">Gas 实时追踪</span>
            <span class="text-lg">⛽</span>
          </a>
          <a href="#" class="flex items-center justify-between p-4 bg-white rounded-2xl border border-slate-100 hover:border-blue-200 transition group">
            <span class="font-bold text-slate-700 group-hover:text-blue-600">回本周期分析</span>
            <span class="text-lg">📉</span>
          </a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
