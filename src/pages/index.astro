---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="GameFi 攻略站 - 首页">
  <!-- Hero Section -->
  <section class="text-center py-16">
    <h1 class="text-5xl font-bold mb-6 bg-gradient-to-r from-gamefi-accent to-purple-500 bg-clip-text text-transparent">
      探索 GameFi 世界
    </h1>
    <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
      最专业的链游攻略平台，为您提供最新的游戏资讯、玩法指南和收益策略
    </p>
    <div class="flex justify-center gap-4">
      <a href="/games" class="bg-gamefi-accent text-gamefi-dark px-8 py-3 rounded-lg font-bold hover:bg-cyan-400 transition">
        浏览游戏
      </a>
      <a href="/blog" class="border border-gamefi-accent text-gamefi-accent px-8 py-3 rounded-lg font-bold hover:bg-gamefi-accent hover:text-gamefi-dark transition">
        阅读攻略
      </a>
    </div>
  </section>

  <!-- 热门游戏 -->
  <section class="py-12">
    <h2 class="text-3xl font-bold mb-8 text-center">🔥 热门游戏</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- 游戏卡片 1 -->
      <div class="bg-gamefi-card rounded-xl overflow-hidden hover:transform hover:scale-105 transition">
        <div class="h-48 bg-gradient-to-br from-purple-600 to-blue-600"></div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2">Axie Infinity</h3>
          <p class="text-gray-400 mb-4">经典链游，收集养成对战</p>
          <div class="flex items-center justify-between">
            <span class="text-gamefi-accent">RON 链</span>
            <a href="/games/axie-infinity" class="text-gamefi-accent hover:underline">详情 →</a>
          </div>
        </div>
      </div>

      <!-- 游戏卡片 2 -->
      <div class="bg-gamefi-card rounded-xl overflow-hidden hover:transform hover:scale-105 transition">
        <div class="h-48 bg-gradient-to-br from-green-600 to-emerald-600"></div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2">StepN</h3>
          <p class="text-gray-400 mb-4">Move to Earn 健身赚币</p>
          <div class="flex items-center justify-between">
            <span class="text-gamefi-accent">Solana 链</span>
            <a href="#" class="text-gamefi-accent hover:underline">详情 →</a>
          </div>
        </div>
      </div>

      <!-- 游戏卡片 3 -->
      <div class="bg-gamefi-card rounded-xl overflow-hidden hover:transform hover:scale-105 transition">
        <div class="h-48 bg-gradient-to-br from-yellow-600 to-orange-600"></div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2">The Sandbox</h3>
          <p class="text-gray-400 mb-4">元宇宙沙盒游戏平台</p>
          <div class="flex items-center justify-between">
            <span class="text-gamefi-accent">Ethereum 链</span>
            <a href="#" class="text-gamefi-accent hover:underline">详情 →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 最新攻略 -->
  <section class="py-12">
    <h2 class="text-3xl font-bold mb-8 text-center">📝 最新攻略</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- 文章卡片 1 -->
      <div class="bg-gamefi-card rounded-xl p-6 hover:border-gamefi-accent border border-transparent transition">
        <h3 class="text-xl font-bold mb-3">GameFi 新手入门指南</h3>
        <p class="text-gray-400 mb-4">从零开始了解 GameFi，包括钱包设置、游戏选择和收益策略...</p>
        <div class="flex items-center justify-between text-sm text-gray-500">
          <span>2026-03-06</span>
          <a href="/blog/getting-started" class="text-gamefi-accent hover:underline">阅读全文 →</a>
        </div>
      </div>

      <!-- 文章卡片 2 -->
      <div class="bg-gamefi-card rounded-xl p-6 hover:border-gamefi-accent border border-transparent transition">
        <h3 class="text-xl font-bold mb-3">如何选择优质 GameFi 项目</h3>
        <p class="text-gray-400 mb-4">教你识别有潜力的链游项目，避开土狗和骗局...</p>
        <div class="flex items-center justify-between text-sm text-gray-500">
          <span>即将发布</span>
          <span class="text-gamefi-accent">敬请期待</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
