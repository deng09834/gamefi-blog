---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'GameFi 攻略站 - 最专业的链游指南' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gamefi-light text-gamefi-text min-h-screen">
    <header class="bg-white border-b border-gamefi-border shadow-sm">
      <nav class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="text-2xl font-bold text-gamefi-accent">
            🎮 GameFi 攻略站
          </a>
          <div class="flex items-center gap-6">
            <a href="/games" class="hover:text-gamefi-accent transition font-medium">游戏库</a>
            <a href="/blog" class="hover:text-gamefi-accent transition font-medium">攻略</a>
            <a href="/tools" class="hover:text-gamefi-accent transition font-medium">工具</a>
            <a href="/about" class="hover:text-gamefi-accent transition font-medium">关于</a>
          </div>
        </div>
      </nav>
    </header>

    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="bg-gamefi-card border-t border-gamefi-border mt-16">
      <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-lg font-bold mb-4 text-gamefi-text">🎮 GameFi 攻略站</h3>
            <p class="text-gamefi-muted text-sm leading-relaxed">
              最专业的链游指南平台，提供深度游戏攻略、收益策略和行业资讯。
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-4 text-gamefi-text">游戏库</h3>
            <ul class="space-y-2 text-gamefi-muted text-sm">
              <li><a href="/games/axie-infinity" class="hover:text-gamefi-accent">Axie Infinity</a></li>
              <li><a href="/games/stepn" class="hover:text-gamefi-accent">StepN</a></li>
              <li><a href="/games" class="hover:text-gamefi-accent">查看全部 →</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-4 text-gamefi-text">热门攻略</h3>
            <ul class="space-y-2 text-gamefi-muted text-sm">
              <li><a href="/blog/earning-strategy" class="hover:text-gamefi-accent">收益最大化策略</a></li>
              <li><a href="/blog/anti-scam" class="hover:text-gamefi-accent">防骗指南</a></li>
              <li><a href="/blog/getting-started" class="hover:text-gamefi-accent">新手入门</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-4 text-gamefi-text">联系我们</h3>
            <ul class="space-y-2 text-gamefi-muted text-sm">
              <li>📧 contact@gamefi-blog.com</li>
              <li>💬 @gamefi_blog</li>
              <li><a href="/about" class="text-gamefi-accent hover:underline">更多联系方式 →</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gamefi-border mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-gamefi-muted text-sm">
            &copy; 2026 GameFi 攻略站。All rights reserved.
          </p>
          <div class="flex gap-6 text-sm text-gamefi-muted">
            <a href="/privacy" class="hover:text-gamefi-accent">隐私政策</a>
            <a href="/terms" class="hover:text-gamefi-accent">使用条款</a>
            <a href="/disclaimer" class="hover:text-gamefi-accent">免责声明</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
